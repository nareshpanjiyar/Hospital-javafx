<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.hospital.controller.PatientPrescriptionsController">
    <top>
        <HBox spacing="15" alignment="CENTER_LEFT" style="-fx-background-color: #2c3e50; -fx-padding: 15;">
            <Button text="← Back to Dashboard" onAction="#handleBack" style="-fx-background-color: transparent; -fx-text-fill: white;"/>
            <Label text="My Prescriptions" style="-fx-text-fill: white; -fx-font-size: 20px; -fx-font-weight: bold;"/>
        </HBox>
    </top>
    <center>
        <VBox spacing="10" alignment="CENTER" style="-fx-padding: 20;">
            <Label fx:id="statusLabel" style="-fx-font-size: 16px;"/>
            <TableView fx:id="prescriptionsTable" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="doctorColumn" text="Doctor" prefWidth="180"/>
                    <TableColumn fx:id="dateColumn" text="Date" prefWidth="150"/>
                    <TableColumn fx:id="diagnosisColumn" text="Diagnosis" prefWidth="200"/>
                    <TableColumn fx:id="statusColumn" text="Status" prefWidth="100"/>
                </columns>
            </TableView>
        </VBox>
    </center>
</BorderPane>