<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.hospital.controller.PatientBillingController">
    <top>
        <HBox spacing="15" alignment="CENTER_LEFT" style="-fx-background-color: #2c3e50; -fx-padding: 15;">
            <Button text="← Back to Dashboard" onAction="#handleBack" style="-fx-background-color: transparent; -fx-text-fill: white;"/>
            <Label text="My Bills" style="-fx-text-fill: white; -fx-font-size: 20px; -fx-font-weight: bold;"/>
        </HBox>
    </top>
    <center>
        <VBox spacing="15" style="-fx-padding: 20;">
            <HBox spacing="20" alignment="CENTER">
                <Label text="Total Pending: " style="-fx-font-weight: bold;"/>
                <Label fx:id="totalPendingLabel" style="-fx-font-size: 16px; -fx-text-fill: #e74c3c;"/>
                <Label text="Total Paid: " style="-fx-font-weight: bold;"/>
                <Label fx:id="totalPaidLabel" style="-fx-font-size: 16px; -fx-text-fill: #27ae60;"/>
            </HBox>
            <Label fx:id="statusLabel" style="-fx-font-style: italic;"/>
            <TableView fx:id="billsTable" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="billIdColumn" text="Bill #" prefWidth="80"/>
                    <TableColumn fx:id="amountColumn" text="Amount" prefWidth="120"/>
                    <TableColumn fx:id="dateColumn" text="Date" prefWidth="120"/>
                    <TableColumn fx:id="descriptionColumn" text="Description" prefWidth="200"/>
                    <TableColumn fx:id="statusColumn" text="Status" prefWidth="100"/>
                </columns>
            </TableView>
        </VBox>
    </center>
</BorderPane>