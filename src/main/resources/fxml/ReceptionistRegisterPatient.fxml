<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.hospital.controller.ReceptionistRegisterPatientController">
    <top>
        <HBox spacing="15" alignment="CENTER_LEFT" style="-fx-background-color: #2c3e50; -fx-padding: 15;">
            <Button text="← Back" onAction="#handleBack" style="-fx-background-color: transparent; -fx-text-fill: white;"/>
            <Label text="Register New Patient" style="-fx-text-fill: white; -fx-font-size: 20px; -fx-font-weight: bold;"/>
        </HBox>
    </top>
    <center>
        <ScrollPane fitToWidth="true">
            <VBox spacing="15" style="-fx-padding: 30;">
                <Label fx:id="messageLabel" style="-fx-font-size: 14px;"/>
                <GridPane hgap="10" vgap="10">
                    <Label text="Username *" style="-fx-font-weight: bold;"/>
                    <TextField fx:id="usernameField" GridPane.columnIndex="1"/>
                    <Label text="Password *" GridPane.rowIndex="1"/>
                    <TextField fx:id="passwordField" GridPane.columnIndex="1" GridPane.rowIndex="1"/>
                    <Label text="Full Name *" GridPane.rowIndex="2"/>
                    <TextField fx:id="nameField" GridPane.columnIndex="1" GridPane.rowIndex="2"/>
                    <Label text="Age *" GridPane.rowIndex="3"/>
                    <TextField fx:id="ageField" GridPane.columnIndex="1" GridPane.rowIndex="3"/>
                    <Label text="Gender" GridPane.rowIndex="4"/>
                    <ComboBox fx:id="genderCombo" GridPane.columnIndex="1" GridPane.rowIndex="4"/>
                    <Label text="Phone *" GridPane.rowIndex="5"/>
                    <TextField fx:id="phoneField" GridPane.columnIndex="1" GridPane.rowIndex="5"/>
                    <Label text="Email" GridPane.rowIndex="6"/>
                    <TextField fx:id="emailField" GridPane.columnIndex="1" GridPane.rowIndex="6"/>
                    <Label text="Address" GridPane.rowIndex="7"/>
                    <TextArea fx:id="addressArea" GridPane.columnIndex="1" GridPane.rowIndex="7" prefRowCount="2"/>
                    <Label text="Blood Group" GridPane.rowIndex="8"/>
                    <ComboBox fx:id="bloodGroupCombo" GridPane.columnIndex="1" GridPane.rowIndex="8"/>
                </GridPane>
                <HBox spacing="15" alignment="CENTER_RIGHT">
                    <Button text="Clear" onAction="#handleClear"/>
                    <Button text="Register Patient" style="-fx-background-color: #3498db; -fx-text-fill: white;" onAction="#handleRegister"/>
                </HBox>
            </VBox>
        </ScrollPane>
    </center>
</BorderPane>