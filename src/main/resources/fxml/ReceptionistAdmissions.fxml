<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.hospital.controller.ReceptionistAdmissionsController">
    <top>
        <HBox spacing="15" alignment="CENTER_LEFT" style="-fx-background-color: #2c3e50; -fx-padding: 15;">
            <Button text="← Back" onAction="#handleBack" style="-fx-background-color: transparent; -fx-text-fill: white;"/>
            <Label text="Admissions / Discharge" style="-fx-text-fill: white; -fx-font-size: 20px; -fx-font-weight: bold;"/>
        </HBox>
    </top>
    <center>
        <VBox spacing="10" style="-fx-padding: 20;">
            <TableView fx:id="patientsTable">
                <columns>
                    <TableColumn fx:id="idCol" text="ID" prefWidth="50"/>
                    <TableColumn fx:id="nameCol" text="Name" prefWidth="150"/>
                    <TableColumn fx:id="phoneCol" text="Phone" prefWidth="120"/>
                    <TableColumn fx:id="admissionDateCol" text="Admission Date" prefWidth="120"/>
                    <TableColumn fx:id="dischargeDateCol" text="Discharge Date" prefWidth="120"/>
                    <TableColumn fx:id="statusCol" text="Status" prefWidth="100"/>
                    <TableColumn fx:id="actionCol" text="Action" prefWidth="150"/>
                </columns>
            </TableView>
        </VBox>
    </center>
</BorderPane>