<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.hospital.controller.BillingManagementController">
    <top>
        <HBox spacing="15" alignment="CENTER_LEFT" style="-fx-background-color: #2c3e50; -fx-padding: 15;">
            <Button text="← Back" onAction="#handleBack" style="-fx-background-color: transparent; -fx-text-fill: white;"/>
            <Label text="Billing Management" style="-fx-text-fill: white; -fx-font-size: 20px; -fx-font-weight: bold;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="➕ Generate Bill" onAction="#handleAdd" style="-fx-background-color: #27ae60; -fx-text-fill: white;"/>
        </HBox>
    </top>
    <center>
        <VBox spacing="10" style="-fx-padding: 20;">
            <HBox spacing="10">
                <TextField fx:id="searchField" promptText="Search by patient..." HBox.hgrow="ALWAYS"/>
                <ComboBox fx:id="statusFilter" promptText="All Status" prefWidth="150"/>
            </HBox>
            <TableView fx:id="billsTable" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="colId" text="Bill #" prefWidth="60"/>
                    <TableColumn fx:id="colPatient" text="Patient" prefWidth="180"/>
                    <TableColumn fx:id="colAmount" text="Amount" prefWidth="100"/>
                    <TableColumn fx:id="colDate" text="Date" prefWidth="120"/>
                    <TableColumn fx:id="colDescription" text="Description" prefWidth="200"/>
                    <TableColumn fx:id="colStatus" text="Status" prefWidth="100"/>
                    <TableColumn fx:id="colActions" text="Actions" prefWidth="120"/>
                </columns>
            </TableView>
        </VBox>
    </center>
</BorderPane>