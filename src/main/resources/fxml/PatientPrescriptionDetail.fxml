<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="15" xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.hospital.controller.PatientPrescriptionDetailController"
      style="-fx-padding: 20; -fx-background-color: white;">
    <HBox spacing="20">
        <VBox spacing="5">
            <Label text="Doctor:" style="-fx-font-weight: bold;"/>
            <Label text="Date:" style="-fx-font-weight: bold;"/>
            <Label text="Diagnosis:" style="-fx-font-weight: bold;"/>
            <Label text="Notes:" style="-fx-font-weight: bold;"/>
            <Label text="Status:" style="-fx-font-weight: bold;"/>
        </VBox>
        <VBox spacing="5">
            <Label fx:id="doctorLabel"/>
            <Label fx:id="dateLabel"/>
            <Label fx:id="diagnosisLabel"/>
            <Label fx:id="notesLabel"/>
            <Label fx:id="statusLabel"/>
        </VBox>
    </HBox>
    <Label text="Medications" style="-fx-font-size: 16px; -fx-font-weight: bold;"/>
    <TableView fx:id="medicationsTable">
        <columns>
            <TableColumn fx:id="drugColumn" text="Drug" prefWidth="150"/>
            <TableColumn fx:id="dosageColumn" text="Dosage" prefWidth="100"/>
            <TableColumn fx:id="frequencyColumn" text="Frequency" prefWidth="120"/>
            <TableColumn fx:id="durationColumn" text="Duration" prefWidth="100"/>
            <TableColumn fx:id="instructionsColumn" text="Instructions" prefWidth="200"/>
        </columns>
    </TableView>
    <HBox alignment="CENTER_RIGHT">
        <Button text="Close" onAction="#handleClose"/>
    </HBox>
</VBox>