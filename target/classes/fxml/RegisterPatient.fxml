<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.hospital.controller.RegisterPatientController"
            style="-fx-background-color: #f4f7fc;">

    <center>
        <ScrollPane fitToWidth="true" style="-fx-background-color: transparent;">
            <VBox spacing="15" alignment="CENTER" maxWidth="500" style="-fx-padding: 30;">
                <Label text="Patient Registration" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
                <Label fx:id="messageLabel" style="-fx-font-size: 14px;" wrapText="true"/>

                <GridPane hgap="10" vgap="10">
                    <Label text="Username *" style="-fx-font-weight: bold;"/>
                    <TextField fx:id="usernameField" GridPane.columnIndex="1"/>

                    <Label text="Password *" GridPane.rowIndex="1"/>
                    <PasswordField fx:id="passwordField" GridPane.columnIndex="1" GridPane.rowIndex="1"/>

                    <Label text="Confirm Password *" GridPane.rowIndex="2"/>
                    <PasswordField fx:id="confirmPasswordField" GridPane.columnIndex="1" GridPane.rowIndex="2"/>

                    <Label text="Full Name *" GridPane.rowIndex="3"/>
                    <TextField fx:id="nameField" GridPane.columnIndex="1" GridPane.rowIndex="3"/>

                    <Label text="Age *" GridPane.rowIndex="4"/>
                    <TextField fx:id="ageField" GridPane.columnIndex="1" GridPane.rowIndex="4"/>

                    <Label text="Gender" GridPane.rowIndex="5"/>
                    <ComboBox fx:id="genderCombo" GridPane.columnIndex="1" GridPane.rowIndex="5" prefWidth="200"/>

                    <Label text="Phone *" GridPane.rowIndex="6"/>
                    <TextField fx:id="phoneField" GridPane.columnIndex="1" GridPane.rowIndex="6"/>

                    <Label text="Email" GridPane.rowIndex="7"/>
                    <TextField fx:id="emailField" GridPane.columnIndex="1" GridPane.rowIndex="7"/>

                    <Label text="Address" GridPane.rowIndex="8"/>
                    <TextArea fx:id="addressArea" GridPane.columnIndex="1" GridPane.rowIndex="8" prefRowCount="3" prefWidth="200"/>

                    <Label text="Blood Group" GridPane.rowIndex="9"/>
                    <ComboBox fx:id="bloodGroupCombo" GridPane.columnIndex="1" GridPane.rowIndex="9" prefWidth="200"/>
                </GridPane>

                <HBox spacing="15" alignment="CENTER">
                    <Button text="Register" onAction="#handleRegister" style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-pref-width: 100;"/>
                    <Button text="Back to Login" onAction="#handleBack" style="-fx-background-color: #95a5a6; -fx-text-fill: white; -fx-pref-width: 100;"/>
                </HBox>
            </VBox>
        </ScrollPane>
    </center>
</BorderPane>