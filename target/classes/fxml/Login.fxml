<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.hospital.controller.LoginController"
            styleClass="login-root">

    <center>
        <VBox alignment="CENTER" maxWidth="400" spacing="20" styleClass="login-box">
            <padding>
                <Insets top="40" right="40" bottom="40" left="40"/>
            </padding>

            <Label text="Hospital Management System" styleClass="login-title">
                <font>
                    <Font name="System Bold" size="22.0"/>
                </font>
            </Label>
            <Label text="Sign in to your account" styleClass="login-subtitle"/>

            <Label fx:id="errorLabel" styleClass="error-label" wrapText="true"/>

            <VBox spacing="5">
                <Label text="Username" styleClass="field-label"/>
                <TextField fx:id="usernameField" promptText="Enter your username" styleClass="login-field"/>
            </VBox>

            <VBox spacing="5">
                <Label text="Password" styleClass="field-label"/>
                <PasswordField fx:id="passwordField" promptText="Enter your password" styleClass="login-field"/>
            </VBox>

            <VBox spacing="5">
                <Label text="Login as" styleClass="field-label"/>
                <ComboBox fx:id="roleCombo" styleClass="login-combo" maxWidth="Infinity"/>
            </VBox>

            <Button fx:id="loginButton" text="Login" onAction="#handleLogin" styleClass="login-button" maxWidth="Infinity"/>

            <Hyperlink fx:id="registerLink" text="New patient? Register here" onAction="#handleRegister" styleClass="register-link"/>
        </VBox>
    </center>
</BorderPane>
